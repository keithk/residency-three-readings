{
  "name": "disagreement-dataset",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run dataset:validate && vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "dataset:validate": "bun run scripts/validate-dataset.ts",
    "dataset:validate:md": "bun dataset/scripts/validate.ts",
    "dataset:build": "bun run scripts/build-dataset.ts && bun dataset/scripts/validate.ts",
    "dataset:test": "bun test dataset/scorer/",
    "dataset:score:example": "bun run dataset/scorer/example.ts",
    "dataset:publish": "bash scripts/publish-dataset.sh"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vue-tsc": "^2.2.0"
  }
}
